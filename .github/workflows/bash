# Инициализируйте git (если не сделано)
git init

# Создайте ветки
git checkout -b main
git checkout -b dev
git checkout -b uat

# Добавьте файлы
git add .
git commit -m "Initial commit with CI/CD"

# Добавьте remote и отправьте
git remote add origin https://github.com/ВАШ_ЛОГИН/craft-club.git
git push -u origin main
git push -u origin dev
git push -u origin uat
